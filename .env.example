# ──────────────────────────────────────
# API Service Configuration
# ──────────────────────────────────────
PORT=3000

# ──────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────
# Use localhost when running services on host machine
# Use postgres when running services inside Docker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/csv_processor
DB_POOL_SIZE=10

# ──────────────────────────────────────
# Redis
# ──────────────────────────────────────
# Use localhost when running services on host machine
# Use redis when running services inside Docker
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL=3600

# ──────────────────────────────────────
# Kafka
# ──────────────────────────────────────
# Use localhost:9092 when running services on host machine
# Use kafka:29092 when running services inside Docker
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=records.uploaded
KAFKA_GROUP_ID=csv-consumer-group
KAFKA_CLIENT_ID_API=csv-api-producer
KAFKA_CLIENT_ID_CONSUMER=csv-consumer

# ──────────────────────────────────────
# Logging
# ──────────────────────────────────────
LOG_LEVEL=info
